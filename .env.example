# ============================================
# JARVIS4 - AI OFFICE Configuration
# ============================================
# Copy this file to .env and fill in your values

# ─── AI API Keys ───────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# ─── OpenRouter (100+ AI models via single API) ──
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Default model (see full list: https://openrouter.ai/models)
# Examples: anthropic/claude-3.5-sonnet, openai/gpt-4o, google/gemini-pro-1.5
#           meta-llama/llama-3.1-70b-instruct, deepseek/deepseek-chat
OPENROUTER_DEFAULT_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_SITE_URL=https://jarvis4.ai
OPENROUTER_APP_NAME=Jarvis4 AI Office

# ─── HuggingFace (FREE image generation) ──────
# Get token at https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# ─── Telegram Bot Tokens ──────────────────
# Each agent has its own Telegram bot
# Create bots via @BotFather on Telegram
TELEGRAM_MASTER_BOT_TOKEN=your_master_bot_token
TELEGRAM_PROJECT_MANAGER_BOT_TOKEN=your_pm_bot_token
TELEGRAM_RESEARCHER_BOT_TOKEN=your_researcher_bot_token
TELEGRAM_PROGRAMMER_BOT_TOKEN=your_programmer_bot_token
TELEGRAM_ANALYST_BOT_TOKEN=your_analyst_bot_token
TELEGRAM_DESIGNER_BOT_TOKEN=your_designer_bot_token
TELEGRAM_ARTIST_BOT_TOKEN=your_artist_bot_token
TELEGRAM_MARKETER_BOT_TOKEN=your_marketer_bot_token

# Main control panel bot
TELEGRAM_CONTROL_BOT_TOKEN=your_control_panel_bot_token

# Authorized user IDs (comma-separated)
TELEGRAM_AUTHORIZED_USERS=123456789,987654321

# ─── Server Settings ──────────────────────
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
WS_HOST=localhost
WS_PORT=8765

# ─── Security ─────────────────────────────
SECRET_KEY=your_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ─── Memory / Database ────────────────────
CHROMA_PATH=./data/memory
KNOWLEDGE_PATH=./data/knowledge

# ─── Voice Settings ───────────────────────
VOICE_ENABLED=true
VOICE_LANGUAGE=ru
TTS_ENGINE=gtts
STT_ENGINE=google

# ─── Logging ──────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./data/logs/jarvis4.log

# ─── Agent Settings ───────────────────────
AGENT_UPDATE_INTERVAL=1.0
TASK_PROCESSING_TIMEOUT=300
MAX_CONCURRENT_TASKS=10

# ─── Agent AI Models (OpenRouter) ────────
# Each agent can use a different AI model
# Format: AGENT_{NAME}_MODEL=provider/model-id
# Full list: https://openrouter.ai/models
# You can also change models at runtime via:
#   Telegram: /model <agent> <model>
#   API: POST /agents/model {"agent_name": "...", "model": "..."}
#
# Popular models:
#   anthropic/claude-3.5-sonnet  — best overall (paid)
#   openai/gpt-4o               — fast & smart (paid)
#   deepseek/deepseek-coder     — best for code (cheap)
#   meta-llama/llama-3.1-70b-instruct — good free option
#   meta-llama/llama-3.1-8b-instruct:free — free, fast
#   mistralai/mistral-7b-instruct:free — free, good for content
#   google/gemini-2.0-flash-001 — fast Google model
#   qwen/qwen-2.5-coder-32b-instruct — good for code
#
AGENT_MASTER_MODEL=anthropic/claude-3.5-sonnet
AGENT_PROJECT_MANAGER_MODEL=google/gemini-2.0-flash-001
AGENT_RESEARCHER_MODEL=google/gemini-2.0-flash-001
AGENT_PROGRAMMER_MODEL=deepseek/deepseek-chat
AGENT_ANALYST_MODEL=google/gemini-2.0-flash-001
AGENT_DESIGNER_MODEL=google/gemini-2.0-flash-001
AGENT_ARTIST_MODEL=google/gemini-2.0-flash-001
AGENT_MARKETER_MODEL=google/gemini-2.0-flash-001
